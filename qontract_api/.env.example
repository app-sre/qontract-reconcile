# qontract-api Environment Variables
# Copy to .env and adjust values for local development

# Application
APP_NAME=qontract-api
VERSION=0.1.0
DEBUG=false

# Logging
LOG_LEVEL=INFO

# Docker/Runtime Configuration
QAPI_START_MODE=api
QAPI_APP_PORT=8000
QAPI_AUTO_RELOAD=1
QAPI_DEBUG=0

# Cache & Broker (Redis or Valkey)
# Default for docker-compose: redis://cache:6379/0
# Default for local dev: redis://localhost:6379/0
CACHE_BROKER_URL=redis://localhost:6379/0

# Celery (optional - defaults to CACHE_BROKER_URL)
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# JWT Authentication (Phase 2)
JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Vault Integration
USE_VAULT=false

# AWS Credentials (Phase 4 - Utility Endpoints)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
